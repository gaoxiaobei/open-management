{
  "name": "open-management",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "workspace",
  "runServices": [
    "mysql",
    "redis",
    "rabbitmq",
    "minio",
    "minio-init",
    "workspace"
  ],
  "workspaceFolder": "/workspaces/open-management",
  "shutdownAction": "stopCompose",
  "remoteUser": "vscode",
  "overrideCommand": false,
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteEnv": {
    "SPRING_PROFILES_ACTIVE": "dev",
    "DB_HOST": "mysql",
    "DB_PORT": "3306",
    "DB_NAME": "open_management",
    "DB_USERNAME": "root",
    "DB_PASSWORD": "Dev0nly!2024",
    "REDIS_HOST": "redis",
    "REDIS_PORT": "6379",
    "REDIS_PASSWORD": "Dev0nly!Redis2024",
    "RABBITMQ_HOST": "rabbitmq",
    "RABBITMQ_PORT": "5672",
    "RABBITMQ_USERNAME": "open_mgmt",
    "RABBITMQ_PASSWORD": "Dev0nly!Mq2024",
    "RABBITMQ_VHOST": "/",
    "MINIO_ENDPOINT": "http://minio:9000",
    "MINIO_ACCESS_KEY": "devops_minio",
    "MINIO_SECRET_KEY": "Dev0nly!Minio2024",
    "MINIO_BUCKET": "open-management",
    "ELECTRON_MIRROR": "https://npmmirror.com/mirrors/electron/"
  },
  "forwardPorts": [
    3000,
    8080
  ],
  "portsAttributes": {
    "3000": {
      "label": "frontend"
    },
    "8080": {
      "label": "backend"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic",
        "maven.executable.preferMavenWrapper": false,
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.watcherExclude": {
          "**/target/**": true,
          "**/node_modules/**": true
        }
      },
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-boot-dev-pack",
        "Vue.volar",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
